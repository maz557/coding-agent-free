# ── Cloud Providers (at least one required) ──
OPENROUTER_API_KEY=sk-or-v1-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...

# ── Local Providers (no API key needed) ──
OLLAMA_HOST=http://localhost:11434/v1
LMSTUDIO_HOST=http://localhost:1234/v1
LLAMACPP_HOST=http://localhost:8080/v1
# LOCAL_TIMEOUT=600000  # Timeout in ms for local models (default: 600000 = 10 min)
# CLOUD_TIMEOUT=120000  # Timeout in ms for cloud models (default: 120000 = 2 min)

# ── Workspace ──
ALLOWED_DIR=./workspace          # Write operations scope (default: ./workspace)
# READ_ALLOWED_DIR=.             # Read operations scope (default: . = everywhere)
# SCRATCH_DIR=./scratch          # Extra allowed directory for temp files

# ── Large Projects (optional) ──
# MAX_EXCHANGES=50
# MAX_TOOL_RESULT_LENGTH=20000

# ── Docker Sandbox (optional) ──
# DOCKER_SANDBOX_ENABLED=true      # Run commands inside a Docker container for isolation
# DOCKER_IMAGE=ubuntu:22.04       # Docker image to use for the sandbox
